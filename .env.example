# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude API for OCR, translation, Q&A, penalty calculation)
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Cloud Messaging (push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Vercel deployment
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id

# App URL (used by Capacitor and API routes)
NEXT_PUBLIC_API_URL=http://localhost:3000

# AI rate limiting & spend caps
DAILY_AI_SPEND_LIMIT_USD=20
PER_USER_DAILY_SPEND_LIMIT_USD=2

# Public app URL — used by analytics and any absolute URL generation
NEXT_PUBLIC_APP_URL=https://your-vercel-deployment.vercel.app

# Enable beta simulation features (set to 'true' for beta testing only)
NEXT_PUBLIC_BETA_SIMULATIONS=false

# Defer tier enforcement during alpha (set to 'true' during alpha, 'false' for production)
NEXT_PUBLIC_DEFER_TIER_ENFORCEMENT=true

# Enable dev-only API endpoints (/api/dev/*) — must be 'false' in production
DEV_ENDPOINTS_ENABLED=false

# Secret for cron job endpoints (generate with: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# Comma-separated list of admin user IDs (for /admin/* routes)
ADMIN_USER_IDS=user-id-1,user-id-2

# Resend HTTP API — used for all transactional email
RESEND_API_KEY=re_xxx
RESEND_FROM_ADDRESS="RentOS <hello@rentos.homes>"
BUG_REPORT_TO=hello@rentos.homes

# DEPRECATED — remove after Resend migration lands. No longer read by any code.
# SMTP credentials for transactional email (Resend/Postmark/etc.)
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# When true, slot purchases are mocked (no real Omise charge). Set to 'false' once Omise is wired.
NEXT_PUBLIC_PAYMENTS_SIMULATED=true
